# Add these to your ~/.zshrc then run: source ~/.zshrc
# Copy to .env and fill in real values. Never commit .env or real secrets.

# Instantly (email campaigns)
export INSTANTLY_API_KEY=""
# Comma-separated sender emails to exclude from leads (our sending mailboxes). Case-insensitive.
export EXCLUDE_SENDER_EMAILS="declan@mail.teameolasmedical.com,richard@hci.digital"
# Any address whose domain is these (or a subdomain) is treated as our mailbox — include parent domains so
# declan@outreach.tryeolasmedical.com and declan@connect.teameolasmedical.com are excluded, not only @mail....
export EXCLUDE_SENDER_DOMAINS="teameolasmedical.com,tryeolasmedical.com,mail.teameolasmedical.com,hci.digital"
export INSTANTLY_API_KEY_VIRGIL=""
export INSTANTLY_API_KEY_RISE=""

# Mission Inbox (email infrastructure)
export MISSION_INBOX_API_KEY_EOLAS=""
export MISSION_INBOX_API_KEY_VIRGIL=""

# Fireflies (meeting transcripts)
export FIREFLIES_API_KEY=""

# Speed-to-response: auto-reply when interested (set to 1 to enable)
export AUTO_REPLY_EMAIL=""
export AUTO_REPLY_LINKEDIN="1"
# Connected mailbox used for POST /emails/reply (API field eaccount) — must match an account in Instantly
export INSTANTLY_REPLY_FROM_EMAIL=""
# Content-driven: NHS case study and Ask Eolas demo URLs (included in suggested replies when relevant)
export EOLAS_NHS_CASE_STUDY_URL=""
export EOLAS_DEMO_VIDEO_URL=""

# Prosp (LinkedIn). Use /test-prosp-pull to pull leads + conversations per campaign.
# API docs: https://prosp.apidocumentation.com/
export PROSP_API_KEY=""
export PROSP_API_BASE="https://prosp.ai"
# LinkedIn profile URL of the Prosp account that sends DMs (must match one connected account exactly).
# Use an account that is Active in Prosp — not "Parked for inactivity" (parked accounts may 404 on send/conversation).
# Example: https://www.linkedin.com/in/yourusername
export PROSP_SENDER=""
# 0 = pull all campaigns; 0 for leads = all leads per campaign (slower). Default 200 leads per campaign.
export PROSP_MAX_CAMPAIGNS="0"
export PROSP_MAX_LEADS_PER_CAMPAIGN="200"

# Slack (communication) — use Bot Token for chat.postMessage
export SLACK_ACCESS_TOKEN=""
export SLACK_REFRESH_TOKEN=""
export SLACK_BOT_TOKEN=""
export SLACK_CHANNEL_ID=""

# OpenAI (AI) — use OpenAI or Azure OpenAI (Azure preferred when set)
export OPENAI_API_KEY=""
# Azure OpenAI (optional; for classify + suggest_reply)
export AZURE_OPENAI_ENDPOINT="https://YOUR_RESOURCE.openai.azure.com"
export AZURE_OPENAI_KEY=""
export AZURE_OPENAI_DEPLOYMENT="TherabotAgent"
export AZURE_OPENAI_API_VERSION="2025-01-01-preview"
